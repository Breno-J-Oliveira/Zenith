generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User (mock, sem auth real ainda) ───
model User {
  id           String   @id @default(cuid())
  email        String
  name         String
  avatar       String?
  theme        String   @default("red")
  createdAt    DateTime @default(now())

  goals        Goal[]
  routines     Routine[]
  appointments Appointment[]
  aiLogs       AILog[]
  pages        Page[]
  databases    Database[]
}

// ─── Goal ───
model Goal {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String       @default("pessoal")
  priority    String       @default("media")
  status      String       @default("ACTIVE")
  deadline    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones  Milestone[]
  tasks       Task[]

  @@index([userId])
}

// ─── Milestone ───
model Milestone {
  id        String   @id @default(cuid())
  goalId    String
  title     String
  deadline  String?
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

// ─── Task (de metas + de rotinas) ───
model Task {
  id          String   @id @default(cuid())
  userId      String
  goalId      String?
  milestoneId String?
  routineId   String?
  title       String
  description String?
  status      String   @default("ACTIVE")
  date        String?
  completed   Boolean  @default(false)
  time        String?  // horário para tasks de rotina (ex: "14:00")
  duration    Int?     // duração em minutos para tasks de rotina
  createdAt   DateTime @default(now())

  goal        Goal?    @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goalId])
  @@index([routineId])
  @@index([date])
}

// ─── Routine ───
model Routine {
  id        String   @id @default(cuid())
  userId    String
  title     String
  frequency String   @default("daily")
  time      String
  duration  Int      @default(60)
  active    Boolean  @default(true)
  adaptable Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Appointment ───
model Appointment {
  id        String   @id @default(cuid())
  userId    String
  title     String
  date      String
  startTime String
  endTime   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ─── AILog ───
model AILog {
  id        String   @id @default(cuid())
  userId    String?
  timestamp DateTime @default(now())
  input     String
  result    String   // JSON serializado de ParsedAIResult

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Page (Notion-like) ───
model Page {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Sem título")
  parentId  String?
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Page?    @relation("PageTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Page[]   @relation("PageTree")
  blocks    Block[]
  databases Database[]

  @@index([userId])
  @@index([parentId])
}

// ─── Block ───
model Block {
  id        String   @id @default(cuid())
  pageId    String
  type      String   // heading, text, todo, task_ref, goal_ref, image, divider
  content   String   // JSON flexível por tipo
  order     Int      @default(0)
  createdAt DateTime @default(now())

  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

// ═══════════════════════════════════════════════════════════
// FASE 8 — Motor de Database Flexível (tipo Notion)
// ═══════════════════════════════════════════════════════════

// ─── Database (base de dados flexível) ───
model Database {
  id          String     @id @default(cuid())
  userId      String
  pageId      String?    // pode viver dentro de uma página, ou ser raiz
  title       String
  icon        String?
  isPreset    Boolean    @default(false)
  presetType  String?    // "finance" | "shopping" | "study" | "habits" | null
  properties  Property[]
  rows        Row[]
  views       View[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  page        Page?      @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([pageId])
}

// ─── Property (coluna/propriedade do database) ───
model Property {
  id          String   @id @default(cuid())
  databaseId  String
  name        String
  type        String   // text | number | currency | date | checkbox | select | multi_select | relation
  options     String?  // JSON — opções de select/multi_select, formato de moeda, etc.
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  database    Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
}

// ─── Row (linha/item do database) ───
model Row {
  id          String   @id @default(cuid())
  databaseId  String
  values      String   // JSON — { propertyId: valor }
  coverImage  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  database    Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
}

// ─── View (visualização do database) ───
model View {
  id          String   @id @default(cuid())
  databaseId  String
  name        String
  type        String   // table | gallery | list | board
  config      String   // JSON — filtros, ordenação, agrupamento
  createdAt   DateTime @default(now())

  database    Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
}

// ═══════════════════════════════════════════════════════════
// FASE 9 — Chat com IA (histórico persistente)
// ═══════════════════════════════════════════════════════════

// ─── ChatThread (conversa com a IA) ───
model ChatThread {
  id          String        @id @default(cuid())
  userId      String
  title       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]

  @@index([userId])
}

// ─── ChatMessage (mensagens do chat) ───
model ChatMessage {
  id          String   @id @default(cuid())
  threadId    String
  role        String   // user | assistant | tool
  content     String
  toolCalls   String?  // JSON — ferramentas chamadas
  createdAt   DateTime @default(now())

  thread      ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

// ═══════════════════════════════════════════════════════════
// FASE 14 — Notificações
// ═══════════════════════════════════════════════════════════

// ─── Notification ───
model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  body        String
  type        String   @default("info") // info | success | warning | error
  read        Boolean  @default(false)
  relatedType String?  // task | goal | appointment | routine
  relatedId   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([read])
}
